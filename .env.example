# Prisma
DATABASE_URL="postgres://root:123456@localhost:5432/local"

# Session — HMAC secret used to sign the session cookie. Use a long random value such as by command: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# API URL — Required by the web app to connect to the API. In development this defaults to http://localhost:3001 if not set.
# For production/Vercel, set this to the deployed API URL (e.g. https://ultra-light-monorepo-api.vercel.app)
API_BASE_URL="http://localhost:3001"

