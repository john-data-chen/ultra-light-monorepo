{
  "mcpServers": {
    "svelte": {
      "type": "http",
      "url": "https://mcp.svelte.dev/mcp"
    },
    "Prisma-Local": {
      "command": "pnpm",
      "args": ["-C", "packages/db", "exec", "prisma", "mcp"]
    },
    "context7": {
      "command": "context7-mcp"
    },
    "chrome-devtools": {
      "command": "chrome-devtools-mcp"
    }
  }
}
