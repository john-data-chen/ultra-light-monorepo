{
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "jsxSingleQuote": false,
  "printWidth": 100,
  "proseWrap": "preserve",
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "none",
  "useTabs": false,
  "embeddedLanguageFormatting": "auto",
  "svelte": true,
  "sortTailwindcss": true,
  "experimentalSortImports": {
    "groups": [
      ["side_effect"],
      ["builtin"],
      ["value-external", "type-external"],
      ["value-internal", "type-internal"],
      ["value-parent", "type-parent"],
      ["value-sibling", "type-sibling"],
      ["value-index", "type-index"]
    ]
  },
  "experimentalSortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    ".DS_Store",
    "*.pem",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    ".pnpm-debug.log*",
    "**/.env*",
    "env.example",
    ".agents",
    "coverage",
    "static",
    "pnpm-lock.yaml",
    "src/lib/server/db/generated"
  ]
}
