{
  "name": "ultra-light-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "commit": "git-cz",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @ultra-light/db run db:migrate",
    "db:push": "pnpm --filter @ultra-light/db run db:push",
    "db:seed": "pnpm --filter @ultra-light/db run db:seed",
    "db:start": "docker compose up",
    "db:studio": "pnpm --filter @ultra-light/db run db:studio",
    "dev": "turbo run dev",
    "format": "oxfmt --write .",
    "lint": "turbo run lint",
    "postinstall": "echo 'Run pnpm run db:generate manually after setting DATABASE_URL'",
    "prepare": "husky || echo ''",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --filter=./apps/* --filter=@ultra-light/shared",
    "test:e2e": "playwright test",
    "test:watch": "turbo run test -- --watch"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/cz-commitlint": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@ultra-light/db": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "commitizen": "^4.3.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.71.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "catalog:",
    "turbo": "^2.10.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "*.svelte": [
      "eslint --fix",
      "oxfmt --write"
    ],
    "*.{css,html,json,md}": "oxfmt --write"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0"
}
