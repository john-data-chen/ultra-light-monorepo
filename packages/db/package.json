{
  "name": "@ultra-light/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=../../.env src/seed.ts",
    "db:studio": "prisma studio",
    "lint": "oxlint src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@ultra-light/shared": "workspace:*",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@ultra-light/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "prisma": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
