datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/lib/server/db/generated"
}

enum TransactionType {
  income
  expense

  @@map("transaction_type")
}

enum UserRole {
  member
  admin

  @@map("user_role")
}

enum AuditAction {
  create
  update
  delete

  @@map("audit_action")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  avatar       String
  role         UserRole      @default(member)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  transactions Transaction[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Transaction {
  id         Int             @id @default(autoincrement())
  userId     Int             @map("user_id")
  type       TransactionType
  category   String
  amount     Int
  occurredOn DateTime        @map("occurred_on") @db.Date
  note       String?
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredOn], map: "transactions_user_occurred_idx")
  @@map("transactions")
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  actorId   Int         @map("actor_id")
  action    AuditAction
  entity    String
  entityId  Int?        @map("entity_id")
  summary   String?
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  actor     User        @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "audit_logs_created_idx")
  @@map("audit_logs")
}
