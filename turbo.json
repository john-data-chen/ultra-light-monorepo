{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": [".svelte-kit/output", "dist", ".next"]
    },
    "@ultra-light/db#build": {
      "dependsOn": ["db:generate", "^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": [".svelte-kit/output", "dist", ".next"]
    },
    "check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["src/generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", ".oxlintrc.json", "eslint.config.js"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.ts", "vitest.shared.ts", "tsconfig.json"],
      "env": ["DATABASE_URL"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.ts", "vitest.shared.ts", "tsconfig.json"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL"]
    }
  }
}
